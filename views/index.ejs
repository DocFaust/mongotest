<%- include("partials/header") -%>

<div class="container">
  <h1>Saldo</h1>

  <div class="container-fluid box">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Saldo</th>
        </tr>
      </thead>
      <tbody
      <% saldoList.forEach((saldo, index)=> { %>
        >
        <tr>
          <td>
            <%= saldo.name %>
          </td>
          <td>
            <%= saldo.value %>
          </td>
        </tr>
        <%});%>

      </tbody>
<tfoot>
  Saldo: <%= completeSaldo %> 
</tfoot>
    </table>
  </div>

  <div class="container-fluid box">
    <h3>Links</h3>
    <div>
      <a href="/player">
        <button type="button" class="btn link">Player</button>
      </a>
    </div>
    <div>
      <a href="/season">
        <button type="button" class="btn link">Season</button>
      </a>
    </div>
  </div>
</div>

<%- include("partials/footer") -%>
